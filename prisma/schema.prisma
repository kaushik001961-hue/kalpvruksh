generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
}

model News {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  image     String?
  content   String
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Project {
  id          String   @id @default(cuid())
  title       String
  image       String?
  description String
  status      String
  location    String?
  createdAt   DateTime @default(now())
}

model Gallery {
  id        String   @id @default(cuid())
  image     String
  caption   String?
  createdAt DateTime @default(now())
}

model Donation {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  amount    Float
  status    String   @default("Pending")
  createdAt DateTime @default(now())
}

model Volunteer {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  city      String
  interest  String
  message   String?
  createdAt DateTime @default(now())
}