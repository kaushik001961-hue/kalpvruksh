generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  REPORTER
  EDITOR
  USER
  VOLUNTEER
  SUPER_ADMIN
}

enum ProjectStatus {
  PLANNED
  ONGOING
  COMPLETED
}

enum DonationStatus {
  PENDING
  SUCCESS
  FAILED
}

model User {
  id        String   @id @default(cuid())
  name      String // <-- Add this back so it doesn't get dropped
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now()) // <-- Add this back so it doesn't get dropped

  volunteer Volunteer?
}

enum VolunteerStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  INACTIVE
}

model Volunteer {
  id String @id @default(cuid())

  // Personal Information
  firstName String
  lastName  String

  email String @unique
  phone String

  gender String?
  dob    DateTime?

  // Address
  address String?
  city    String
  state   String?
  country String  @default("India")
  pincode String?

  // Professional Information
  occupation   String?
  organization String?
  education    String?

  // Volunteer Information
  interest     String
  skills       String?
  languages    String?
  availability String?

  // Emergency Contact
  emergencyName  String?
  emergencyPhone String?

  // Additional Information
  message String?

  // Admin
  status VolunteerStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])
  photo String?
  resume String?
}

model News {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  image     String?
  content   String
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Project {
  id          String        @id @default(cuid())
  title       String
  image       String?
  description String
  status      ProjectStatus @default(PLANNED)
  location    String?
  createdAt   DateTime      @default(now())
}

model Gallery {
  id        String   @id @default(cuid())
  image     String
  caption   String?
  createdAt DateTime @default(now())
}

model Activity {
  id          String   @id @default(cuid())
  title       String
  image       String?
  description String
  date        DateTime
  createdAt   DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  createdAt DateTime @default(now())
}

model SiteSettings {
  id           String  @id @default(cuid())
  organization String
  email        String
  phone        String
  address      String
  facebook     String?
  instagram    String?
  youtube      String?
}

model Donation {
  id        String         @id @default(cuid())
  name      String
  email     String?
  phone     String?
  amount    Float
  status    DonationStatus @default(PENDING)
  createdAt DateTime       @default(now())
}
