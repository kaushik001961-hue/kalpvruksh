generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  REPORTER
  EDITOR
  USER
  VOLUNTEER
  SUPER_ADMIN
}

enum ProjectStatus {
  PLANNED
  ONGOING
  COMPLETED
}

enum DonationStatus {
  PENDING
  SUCCESS
  FAILED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(VOLUNTEER)
  createdAt DateTime @default(now())
}

model Volunteer {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String
  city      String
  interest  String
  message   String?
  createdAt DateTime @default(now())
}

model News {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  image     String?
  content   String
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Project {
  id          String        @id @default(cuid())
  title       String
  image       String?
  description String
  status      ProjectStatus @default(PLANNED)
  location    String?
  createdAt   DateTime      @default(now())
}

model Gallery {
  id        String   @id @default(cuid())
  image     String
  caption   String?
  createdAt DateTime @default(now())
}

model Activity {
  id          String   @id @default(cuid())
  title       String
  image       String?
  description String
  date        DateTime
  createdAt   DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  createdAt DateTime @default(now())
}

model SiteSettings {
  id           String  @id @default(cuid())
  organization String
  email        String
  phone        String
  address      String
  facebook     String?
  instagram    String?
  youtube      String?
}

model Donation {
  id        String         @id @default(cuid())
  name      String
  email     String?
  phone     String?
  amount    Float
  status    DonationStatus @default(PENDING)
  createdAt DateTime       @default(now())
}
